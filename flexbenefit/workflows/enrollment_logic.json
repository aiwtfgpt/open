{
  "name": "FlexBenefit_Validation_Engine",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "enrollment-submit",
        "options": {}
      },
      "id": "1",
      "name": "Webhook",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1,
      "position": [250, 300]
    },
    {
      "parameters": {
        "filePath": "/home/handy/flexbenefit/data/mock_employees/employees.json"
      },
      "id": "2",
      "name": "Read Mock Ledger",
      "type": "n8n-nodes-base.readBinaryFile",
      "typeVersion": 1,
      "position": [450, 300]
    },
    {
      "parameters": {
        "conditions": {
          "number": [
            {
              "value1": "={{$json.selected_benefit_cost}}",
              "operation": "larger",
              "value2": "={{$json.available_flex_spend}}"
            }
          ]
        }
      },
      "id": "3",
      "name": "Check Balance",
      "type": "n8n-nodes-base.if",
      "typeVersion": 1,
      "position": [650, 300]
    },
    {
      "parameters": {
        "respondWith": "text",
        "responseBody": "Insufficient Funds. Your remaining balance is only ${{ $json.available_flex_spend }}"
      },
      "id": "4",
      "name": "Error Response",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1,
      "position": [850, 200]
    },
    {
      "parameters": {
        "respondWith": "text",
        "responseBody": "Success! Enrollment recorded."
      },
      "id": "5",
      "name": "Success Response",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1,
      "position": [850, 400]
    }
  ],
  "connections": {
    "1": {
      "main": [
        [
          {
            "node": "2",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "2": {
      "main": [
        [
          {
            "node": "3",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "3": {
      "main": [
        [
          {
            "node": "4",
            "type": "main",
            "index": 0
          }
        ],
        [
          {
            "node": "5",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  }
}
